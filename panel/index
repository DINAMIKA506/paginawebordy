<style>
:root{
  --morado:#4E4BF7; --coral:#F94646; --lila:#BBBBFC;
  --lila-suave:#EFEFFF; --fondo:#F6F6FF; --tinta:#23214A;
  --gris:#6B6A8A; --blanco:#FFFFFF; --verde:#1FA97C; --ambar:#E8930C;
  --radio:16px; --sombra:0 4px 18px rgba(78,75,247,.10);
}
*{box-sizing:border-box; margin:0; padding:0;}
body{font-family:'Inter',sans-serif; background:var(--fondo); color:var(--tinta); min-height:100vh;}
h1,h2,h3{font-family:'Fraunces',serif;}
button{font-family:'Inter',sans-serif; cursor:pointer;}

/* ── Portón de acceso ── */
#gate{position:fixed; inset:0; background:var(--morado); z-index:100; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:18px; padding:24px; text-align:center;}
#gate img{height:52px; background:var(--blanco); padding:12px 22px; border-radius:14px;}
#gate h1{color:var(--blanco); font-size:1.5rem;}
#gate p{color:var(--lila); font-size:.95rem;}
#gate input{padding:13px 16px; border-radius:12px; border:none; font-size:1rem; width:min(300px,80vw); text-align:center;}
#gate button{background:var(--coral); color:var(--blanco); border:none; padding:13px 34px; border-radius:12px; font-weight:700; font-size:1rem;}
#gate .error{color:#FFD9D9; font-size:.9rem; min-height:1.2em;}

/* ── Encabezado ── */
header{background:var(--morado); color:var(--blanco); padding:22px 20px 0;}
.head-inner{max-width:1100px; margin:0 auto; display:flex; flex-wrap:wrap; align-items:center; gap:14px;}
.head-inner img{height:42px; background:var(--blanco); padding:8px 14px; border-radius:12px;}
.head-inner h1{font-size:1.35rem; flex:1; min-width:200px;}
.head-btns{display:flex; gap:8px; flex-wrap:wrap;}
.head-btns button{background:rgba(255,255,255,.14); color:var(--blanco); border:1px solid rgba(255,255,255,.35); padding:9px 14px; border-radius:10px; font-weight:600; font-size:.85rem;}
.head-btns button.primario{background:var(--coral); border-color:var(--coral);}
.ola{display:block; width:100%; margin-top:18px;}
.tabs{max-width:1100px; margin:0 auto; display:flex; gap:6px; padding-top:14px;}
.tabs button{background:transparent; border:none; color:var(--lila); font-weight:700; font-size:.95rem; padding:10px 16px; border-radius:12px 12px 0 0;}
.tabs button.activo{background:var(--fondo); color:var(--morado);}

main{max-width:1100px; margin:0 auto; padding:22px 20px 80px;}

/* ── Resumen ── */
.stats{display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; margin-bottom:22px;}
.stat{background:var(--blanco); border-radius:var(--radio); padding:16px 18px; box-shadow:var(--sombra);}
.stat b{font-size:1.6rem; font-family:'Fraunces',serif; color:var(--morado); display:block;}
.stat span{font-size:.82rem; color:var(--gris); font-weight:600;}
.stat.alerta b{color:var(--coral);}

/* ── Tarjetas de cliente ── */
.card{background:var(--blanco); border-radius:var(--radio); box-shadow:var(--sombra); margin-bottom:14px; overflow:hidden; border-left:6px solid var(--lila);}
.card.tiene-accion{border-left-color:var(--coral);}
.card.en-espera{border-left-color:var(--lila);}
.card-head{display:flex; flex-wrap:wrap; align-items:center; gap:10px 14px; padding:16px 18px; cursor:pointer;}
.card-head .nombre{flex:1; min-width:180px;}
.card-head .nombre b{font-size:1.05rem; font-family:'Fraunces',serif;}
.card-head .nombre span{display:block; font-size:.82rem; color:var(--gris);}
.chip{font-size:.75rem; font-weight:700; padding:5px 11px; border-radius:99px; white-space:nowrap;}
.chip.nivel{background:var(--lila-suave); color:var(--morado);}
.chip.accion{background:#FFE9E9; color:var(--coral);}
.chip.espera{background:#EDEDF5; color:var(--gris);}
.chip.ok{background:#E2F6EE; color:var(--verde);}
.chip.aviso{background:#FFF3DF; color:var(--ambar);}
.card-body{display:none; border-top:1px solid #ECECF8; padding:18px;}
.card.abierta .card-body{display:block;}

.grid2{display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:12px; margin-bottom:14px;}
.campo label{display:block; font-size:.75rem; font-weight:700; color:var(--gris); margin-bottom:4px; text-transform:uppercase; letter-spacing:.03em;}
.campo input, .campo select, .campo textarea{width:100%; padding:10px 12px; border:1.5px solid #DEDEF2; border-radius:10px; font-size:.92rem; font-family:'Inter',sans-serif; background:var(--blanco); color:var(--tinta);}
.campo textarea{min-height:74px; resize:vertical;}
.campo input:focus, .campo select:focus, .campo textarea:focus{outline:2px solid var(--morado); border-color:var(--morado);}

.bloque{background:var(--fondo); border-radius:12px; padding:16px; margin-top:14px;}
.bloque h3{font-size:1rem; color:var(--morado); margin-bottom:10px; display:flex; align-items:center; gap:8px; flex-wrap:wrap;}
.aviso-caja{background:#FFF3DF; border-left:4px solid var(--ambar); border-radius:10px; padding:12px 14px; font-size:.9rem; margin-top:12px; font-weight:600;}
.aviso-caja.roja{background:#FFE9E9; border-left-color:var(--coral); color:var(--coral);}
.msg-out{background:var(--blanco); border:1.5px solid #DEDEF2; border-radius:10px; padding:12px 14px; font-size:.9rem; white-space:pre-wrap; max-height:260px; overflow:auto; line-height:1.55;}
.botonera{display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;}
.btn{border:none; border-radius:10px; padding:10px 16px; font-weight:700; font-size:.87rem; display:inline-flex; align-items:center; gap:6px;}
.btn.morado{background:var(--morado); color:var(--blanco);}
.btn.coral{background:var(--coral); color:var(--blanco);}
.btn.verde{background:var(--verde); color:var(--blanco);}
.btn.linea{background:var(--blanco); color:var(--morado); border:1.5px solid var(--morado);}
.btn.gris{background:#EDEDF5; color:var(--gris);}
.btn:disabled{opacity:.45; cursor:not-allowed;}

.preview-mail{border:1.5px solid #DEDEF2; border-radius:12px; overflow:auto; max-height:520px; background:#F3F2FF; margin-top:10px;}
.coleccion-mini{font-size:.85rem; background:var(--blanco); border:1.5px dashed var(--lila); border-radius:10px; padding:10px 12px; margin-top:10px; line-height:1.7;}

/* ── Registro ── */
table{width:100%; border-collapse:collapse; background:var(--blanco); border-radius:var(--radio); overflow:hidden; box-shadow:var(--sombra); font-size:.86rem;}
th{background:var(--morado); color:var(--blanco); text-align:left; padding:11px 12px; font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;}
td{padding:10px 12px; border-top:1px solid #ECECF8;}
tr:hover td{background:var(--lila-suave);}

/* ── Modales ── */
.modal-fondo{position:fixed; inset:0; background:rgba(35,33,74,.55); z-index:60; display:none; align-items:flex-start; justify-content:center; padding:30px 16px; overflow:auto;}
.modal-fondo.visible{display:flex;}
.modal{background:var(--blanco); border-radius:var(--radio); max-width:640px; width:100%; padding:24px; box-shadow:0 12px 40px rgba(0,0,0,.25);}
.modal h2{color:var(--morado); font-size:1.25rem; margin-bottom:16px;}
.vacio{text-align:center; padding:50px 20px; color:var(--gris);}
.vacio .emoji{font-size:2.6rem; display:block; margin-bottom:10px;}
.toast{position:fixed; bottom:22px; left:50%; transform:translateX(-50%); background:var(--tinta); color:var(--blanco); padding:12px 22px; border-radius:99px; font-weight:600; font-size:.9rem; z-index:90; opacity:0; transition:opacity .25s; pointer-events:none;}
.toast.visible{opacity:1;}
.nota-pie{font-size:.78rem; color:var(--gris); margin-top:8px;}
@media(max-width:640px){ .card-head{padding:14px;} .card-body{padding:14px;} }
</style>
</head>
<body>

<!-- Portón de acceso -->
<div id="gate">
  <img src="https://www.ordenyplan.com/img/insignias/ordy-logo.png" alt="Ordy">
  <h1>Panel de Acompañamiento</h1>
  <p>Espacio interno del equipo Ordy 🌊</p>
  <input type="password" id="gate-pass" placeholder="Contraseña" onkeydown="if(event.key==='Enter')entrar()">
  <div class="error" id="gate-error"></div>
  <button onclick="entrar()">Entrar</button>
</div>

<header>
  <div class="head-inner">
    <img src="https://www.ordenyplan.com/img/insignias/ordy-logo.png" alt="Ordy">
    <h1>Panel de Acompañamiento</h1>
    <div class="head-btns">
      <button class="primario" onclick="abrirNuevoCliente()">+ Nueva empresa</button>
      <button onclick="descargarRespaldo()">⬇ Respaldo</button>
      <button onclick="document.getElementById('cargar-json').click()">⬆ Cargar</button>
      <button onclick="abrirConfig()">⚙ Configuración</button>
      <input type="file" id="cargar-json" accept=".json" style="display:none" onchange="cargarRespaldo(this)">
    </div>
  </div>
  <div class="tabs">
    <button id="tab-clientes" class="activo" onclick="mostrarTab('clientes')">Empresas</button>
    <button id="tab-registro" onclick="mostrarTab('registro')">Registro de envíos</button>
  </div>
</header>

<main>
  <section id="vista-clientes">
    <div class="stats" id="stats"></div>
    <div id="lista-clientes"></div>
  </section>

  <section id="vista-registro" style="display:none">
    <div id="tabla-registro"></div>
  </section>
</main>

<!-- Modal configuración -->
<div class="modal-fondo" id="modal-config">
  <div class="modal">
    <h2>⚙ Configuración general</h2>
    <div class="grid2">
      <div class="campo"><label>WhatsApp de Ordy (para "Activar Radar")</label><input id="cfg-wa" placeholder="50688887777"></div>
      <div class="campo"><label>Link de la comunidad</label><input id="cfg-comunidad" placeholder="https://..."></div>
    </div>
    <p class="nota-pie">Los links de los niveles 1–6 y las insignias ya están integrados en el panel.</p>
    <div class="botonera">
      <button class="btn morado" onclick="guardarConfig()">Guardar</button>
      <button class="btn gris" onclick="cerrarModal('modal-config')">Cancelar</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

