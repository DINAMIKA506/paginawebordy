<script>
/* ═══════════ ESTADO DE LA APP ═══════════ */
const PASS = 'faro2026';
let clientes = JSON.parse(localStorage.getItem('ordy-clientes') || '[]');
let registro = JSON.parse(localStorage.getItem('ordy-registro') || '[]');
let config   = JSON.parse(localStorage.getItem('ordy-config')   || '{"wa":"","comunidad":""}');

function guardar(){
  localStorage.setItem('ordy-clientes', JSON.stringify(clientes));
  localStorage.setItem('ordy-registro', JSON.stringify(registro));
  localStorage.setItem('ordy-config', JSON.stringify(config));
}
function hoy(){ return new Date().toISOString().slice(0,10); }
function diasDesde(fecha){
  if(!fecha) return 999;
  return Math.floor((new Date(hoy()) - new Date(fecha)) / 86400000);
}
function esc(t){ return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('visible');
  setTimeout(()=>t.classList.remove('visible'), 2200);
}

/* ═══════════ PORTÓN ═══════════ */
if(sessionStorage.getItem('ordy-gate') === 'ok') document.getElementById('gate').style.display = 'none';
function entrar(){
  if(document.getElementById('gate-pass').value === PASS){
    sessionStorage.setItem('ordy-gate','ok');
    document.getElementById('gate').style.display = 'none';
  } else {
    document.getElementById('gate-error').textContent = 'Contraseña incorrecta. Intentá de nuevo 🌊';
  }
}

/* ═══════════ MOTOR DE DECISIÓN (la lógica del Cerebro) ═══════════ */
function analizar(c){
  const dias = diasDesde(c.ultimoContacto);
  const n = parseInt(c.nivel) || 1;

  // Alerta de protección
  let alerta = '';
  if(c.activo !== 'Sí') alerta = 'Cliente inactivo';
  else if(n <= 3 && c.estado === 'Recibido' && c.claridad !== 'Sí') alerta = '🚫 No desbloquear: falta claridad mínima';
  else if(c.estado === 'Necesita afinar') alerta = '⚠️ Enviar preguntas antes de avanzar';
  else if(c.estado === 'Pendiente' && dias >= 5) alerta = '⏰ Recordatorio pendiente hace ' + dias + ' días';

  // Acción sugerida + plantilla
  let accion = '', tpl = null;
  if(c.activo !== 'Sí'){ accion = 'Cliente inactivo'; }
  else if(c.estado === 'Nuevo'){ accion = 'Enviar bienvenida'; tpl = 'BIENVENIDA'; }
  else if(c.estado === 'Necesita afinar'){ accion = 'Enviar mensaje de afinación'; tpl = 'AFINAR'; }
  else if(c.estado === 'Desbloqueado'){ accion = n < 6 ? 'Enviar insignia + siguiente nivel' : 'Enviar insignia final + invitar al Radar'; tpl = 'DESBLOQUEO_' + Math.min(n,6); }
  else if(c.estado === 'Pendiente'){ 
    if(dias >= 3){ accion = 'Enviar recordatorio'; tpl = 'RECORDATORIO_' + Math.min(Math.max(n,1),6); }
    else accion = 'Esperar (' + (3 - dias) + ' días para recordatorio)';
  }
  else if(c.estado === 'Radar listo'){ accion = 'Enviar Radar + comunidad'; tpl = 'RADAR'; }
  else if(c.estado === 'Recibido'){ accion = 'En revisión del Motor'; }
  else if(c.estado === 'En revisión'){ accion = 'Revisando — no enviar nada todavía'; }
  else if(c.estado === 'Pausado'){ accion = 'En pausa — no enviar'; }
  else if(c.estado === 'Ruta completada'){ accion = 'Preparar el Radar de Fugas'; }
  else accion = 'Revisar manualmente';

  // Bloqueo de seguridad: si la alerta dice no desbloquear, no ofrecer plantilla de desbloqueo
  if(alerta.startsWith('🚫') && tpl && tpl.startsWith('DESBLOQUEO')) tpl = null;

  return { accion, tpl, alerta, dias };
}

/* ═══════════ COLECCIÓN DE INSIGNIAS ═══════════ */
function coleccionTexto(c){
  const u = parseInt(c.ultimoDesbloqueado) || 0;
  const partes = [];
  for(let i=1; i<=6; i++){
    const nv = NIVELES[i];
    partes.push(nv.emoji + ' N' + i + ' ' + nv.personaje + ' ' + (u >= i ? '✅' : '🔒'));
  }
  partes.push('🐉 Radar Azul ' + (c.estado === 'Radar listo' || c.radarEnviado ? '✅' : '🔒'));
  return partes.join(' | ');
}
function coleccionHTML(c){
  const u = parseInt(c.ultimoDesbloqueado) || 0;
  let celdas = '';
  for(let i=1; i<=6; i++){
    const on = u >= i;
    celdas += '<td align="center" style="padding:4px;">' +
      '<img src="' + NIVELES[i].img + '" width="58" alt="Nivel ' + i + '" style="display:block;border-radius:8px;' + (on ? '' : 'opacity:0.22;') + '">' +
      '<span style="font-size:11px;color:' + (on ? '#4E4BF7' : '#B4B3CE') + ';font-family:Arial,sans-serif;font-weight:bold;">' + (on ? '✅' : '🔒') + '</span></td>';
  }
  const radarOn = c.estado === 'Radar listo' || c.radarEnviado;
  celdas += '<td align="center" style="padding:4px;"><div style="font-size:34px;line-height:58px;' + (radarOn ? '' : 'opacity:0.25;') + '">🐉</div>' +
    '<span style="font-size:11px;color:' + (radarOn ? '#4E4BF7' : '#B4B3CE') + ';font-family:Arial,sans-serif;font-weight:bold;">' + (radarOn ? '✅' : '🔒') + '</span></td>';
  return '<table role="presentation" cellpadding="0" cellspacing="0" align="center"><tr>' + celdas + '</tr></table>';
}

/* ═══════════ SUSTITUCIÓN DE VARIABLES ═══════════ */
function sustituir(texto, c, modo){
  const n = parseInt(c.nivel) || 1;
  const nv = NIVELES[Math.min(Math.max(n,1),6)];
  const sig = NIVELES[n+1];
  const insigniaTxt = 'Insignia "' + nv.insignia + '" ' + nv.emoji;
  return texto
    .replaceAll('{NOMBRE}', c.nombre || '')
    .replaceAll('{EMPRESA}', c.empresa || '')
    .replaceAll('{N}', n)
    .replaceAll('{LINK_NIVEL}', nv.link)
    .replaceAll('{LINK_SIGUIENTE}', sig ? sig.link : '')
    .replaceAll('{INSIGNIA}', modo === 'html' ? '' : insigniaTxt)
    .replaceAll('{MOTOR}', c.motor || '[Pendiente: mensaje del Motor]')
    .replaceAll('{PREGUNTAS}', c.preguntas || '[Pendiente: preguntas de afinación]')
    .replaceAll('{LINK_RADAR}', c.linkRadar || '[Pendiente: link del Radar]')
    .replaceAll('{LINK_COMUNIDAD}', config.comunidad || '[Pendiente: configurar link de comunidad]')
    .replaceAll('{WHATSAPP_ORDY}', config.wa ? 'https://wa.me/' + config.wa : '[Pendiente: configurar WhatsApp de Ordy]');
}

function mensajeWA(c, tplKey){
  let texto = sustituir(TPL[tplKey].wa, c, 'texto');
  if(tplKey.startsWith('DESBLOQUEO') || tplKey === 'RADAR'){
    texto += '\n\nTu colección Ordy hasta ahora:\n' + coleccionTexto(c);
  }
  return texto;
}

/* ═══════════ CORREO BONITO (HTML) ═══════════ */
function correoHTML(c, tplKey){
  const n = parseInt(c.nivel) || 1;
  const nv = NIVELES[Math.min(Math.max(n,1),6)];
  const esDesbloqueo = tplKey.startsWith('DESBLOQUEO');
  const esRadar = tplKey === 'RADAR';
  const asunto = sustituir(TPL[tplKey].asunto, c, 'texto');

  // Cuerpo: cada párrafo del texto se convierte en <p>; el bloque {MOTOR} se resalta
  const crudo = TPL[tplKey].correo;
  let parrafos = '';
  crudo.split('\n\n').forEach(p => {
    const pSust = sustituir(p, c, 'html').trim();
    if(!pSust) return;
    if(p.includes('{MOTOR}') && (c.motor || '').trim()){
      parrafos += '<table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="background:#EFEFFF;border-left:4px solid #4E4BF7;border-radius:10px;padding:14px 16px;font-size:15px;line-height:1.6;color:#3A3870;font-style:italic;">' + esc(sustituir('{MOTOR}', c, 'texto')).replace(/\n/g,'<br>') + '</td></tr></table><div style="height:16px;"></div>';
    } else if(p.includes('{PREGUNTAS}')){
      parrafos += '<table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr><td style="background:#FFF6F6;border-left:4px solid #F94646;border-radius:10px;padding:14px 16px;font-size:15px;line-height:1.7;color:#5A2020;">' + esc(sustituir('{PREGUNTAS}', c, 'texto')).replace(/\n/g,'<br>') + '</td></tr></table><div style="height:16px;"></div>';
    } else if(p.trim().startsWith('Insignia')){
      // La insignia se muestra como imagen, no como texto
    } else if(p.includes('Mensaje del Motor')){
      parrafos += '<p style="margin:0 0 8px;font-size:13px;font-weight:bold;color:#4E4BF7;text-transform:uppercase;letter-spacing:1px;font-family:Arial,sans-serif;">Mensaje del Motor de Interpretación</p>';
    } else {
      const linea = esc(pSust).replace(/\n/g,'<br>');
      parrafos += '<p style="margin:0 0 16px;font-size:15px;line-height:1.65;color:#3A3870;">' + linea + '</p>';
    }
  });

  // Botón principal
  let botonUrl = '', botonTxt = '';
  if(tplKey === 'BIENVENIDA' || tplKey.startsWith('RECORDATORIO')){ botonUrl = nv.link; botonTxt = 'Completar mi Nivel ' + n + ' →'; }
  else if(esDesbloqueo && n < 6 && NIVELES[n+1]){ botonUrl = NIVELES[n+1].link; botonTxt = 'Ir a mi Nivel ' + (n+1) + ' →'; }
  else if(tplKey === 'DESBLOQUEO_6' && config.wa){ botonUrl = 'https://wa.me/' + config.wa; botonTxt = 'Quiero activar mi Radar 🐉'; }
  else if(esRadar && c.linkRadar){ botonUrl = c.linkRadar; botonTxt = 'Ver mi Radar Ordy →'; }
  const boton = botonUrl ? '<table role="presentation" cellpadding="0" cellspacing="0" align="center"><tr><td style="background:#F94646;border-radius:12px;"><a href="' + botonUrl + '" style="display:inline-block;padding:14px 34px;color:#FFFFFF;font-weight:bold;font-size:15px;text-decoration:none;font-family:Arial,sans-serif;">' + botonTxt + '</a></td></tr></table>' : '';

  // Insignia grande (solo en desbloqueos)
  const insigniaImg = esDesbloqueo ? '<img src="' + nv.img + '" width="190" alt="Insignia Nivel ' + n + ': ' + esc(nv.insignia) + '" style="display:block;margin:0 auto 6px;"><p style="text-align:center;margin:0 0 20px;font-size:14px;font-weight:bold;color:#4E4BF7;font-family:Arial,sans-serif;">Insignia desbloqueada: ' + esc(nv.insignia) + ' ' + nv.emoji + '</p>' : '';

  const coleccion = (esDesbloqueo || esRadar) ? '<div style="height:10px;"></div><p style="text-align:center;margin:0 0 10px;font-size:13px;font-weight:bold;color:#4E4BF7;text-transform:uppercase;letter-spacing:1px;font-family:Arial,sans-serif;">Mi colección Ordy</p>' + coleccionHTML(c) + '<div style="height:6px;"></div>' : '';

  return {
    asunto,
    html:
'<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#F3F2FF;padding:26px 12px;"><tr><td align="center">' +
'<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#FFFFFF;border-radius:18px;overflow:hidden;font-family:Arial,Helvetica,sans-serif;">' +
'<tr><td style="background:#4E4BF7;padding:22px;text-align:center;"><img src="' + IMG_BASE + 'ordy-logo.png" width="150" alt="Ordy · orden y plan" style="background:#FFFFFF;border-radius:12px;padding:10px 18px;"></td></tr>' +
'<tr><td style="padding:30px 34px 10px;">' +
'<h1 style="margin:0 0 20px;font-size:23px;line-height:1.3;color:#23214A;font-family:Georgia,\'Times New Roman\',serif;text-align:center;">' + esc(asunto) + '</h1>' +
insigniaImg + parrafos + boton + coleccion +
'</td></tr>' +
'<tr><td style="background:#EFEFFF;padding:18px;text-align:center;font-size:12px;color:#6B6A8A;">Ordy · orden y plan 🌊 · <a href="https://www.ordenyplan.com" style="color:#4E4BF7;text-decoration:none;font-weight:bold;">ordenyplan.com</a><br>Crecemos con propósito, un nivel a la vez.</td></tr>' +
'</table></td></tr></table>'
  };
}
</script>


<script>
/* ═══════════ INTERFAZ ═══════════ */
let abiertaId = null;

function mostrarTab(t){
  document.getElementById('vista-clientes').style.display = t === 'clientes' ? '' : 'none';
  document.getElementById('vista-registro').style.display = t === 'registro' ? '' : 'none';
  document.getElementById('tab-clientes').classList.toggle('activo', t === 'clientes');
  document.getElementById('tab-registro').classList.toggle('activo', t === 'registro');
  if(t === 'registro') pintarRegistro();
}

function pintarStats(){
  const activos = clientes.filter(c => c.activo === 'Sí');
  const conAccion = activos.filter(c => analizar(c).tpl);
  const conAlerta = activos.filter(c => analizar(c).alerta && c.activo === 'Sí');
  document.getElementById('stats').innerHTML =
    '<div class="stat"><b>' + activos.length + '</b><span>Empresas activas</span></div>' +
    '<div class="stat"><b>' + conAccion.length + '</b><span>Mensajes por enviar</span></div>' +
    '<div class="stat alerta"><b>' + conAlerta.length + '</b><span>Alertas del Cerebro</span></div>' +
    '<div class="stat"><b>' + registro.length + '</b><span>Envíos registrados</span></div>';
}

function pintarClientes(){
  pintarStats();
  const cont = document.getElementById('lista-clientes');
  if(clientes.length === 0){
    cont.innerHTML = '<div class="vacio"><span class="emoji">🐬</span>Todavía no hay empresas en el panel.<br>Agregá la primera con el botón <b>+ Nueva empresa</b>.</div>';
    return;
  }
  // Orden: primero las que tienen acción pendiente
  const orden = [...clientes].sort((a,b) => (analizar(b).tpl ? 1 : 0) - (analizar(a).tpl ? 1 : 0));
  cont.innerHTML = orden.map(c => {
    const an = analizar(c);
    const n = parseInt(c.nivel) || 1;
    const nv = NIVELES[Math.min(Math.max(n,1),6)];
    const chipAccion = an.tpl
      ? '<span class="chip accion">📣 ' + esc(an.accion) + '</span>'
      : '<span class="chip espera">' + esc(an.accion) + '</span>';
    const chipAlerta = an.alerta ? '<span class="chip aviso">' + esc(an.alerta.split(':')[0]) + '</span>' : '';
    return '<div class="card ' + (an.tpl ? 'tiene-accion' : 'en-espera') + (abiertaId === c.id ? ' abierta' : '') + '" id="card-' + c.id + '">' +
      '<div class="card-head" onclick="alternar(\'' + c.id + '\')">' +
        '<div class="nombre"><b>' + esc(c.empresa) + '</b><span>' + esc(c.nombre) + ' · ' + esc(c.canal || 'Canal sin definir') + '</span></div>' +
        '<span class="chip nivel">' + nv.emoji + ' Nivel ' + n + ' · ' + esc(c.estado) + '</span>' +
        chipAlerta + chipAccion +
      '</div>' +
      '<div class="card-body">' + (abiertaId === c.id ? cuerpoCliente(c, an) : '') + '</div>' +
    '</div>';
  }).join('');
}

function alternar(id){
  abiertaId = abiertaId === id ? null : id;
  pintarClientes();
  if(abiertaId){
    const el = document.getElementById('card-' + id);
    if(el) el.scrollIntoView({behavior:'smooth', block:'start'});
  }
}

function cuerpoCliente(c, an){
  let h = '<div class="grid2">' +
    campo(c,'empresa','Empresa','text') +
    campo(c,'nombre','Nombre de contacto','text') +
    campo(c,'whatsapp','WhatsApp','text') +
    campo(c,'correo','Correo','text') +
    select(c,'canal','Canal preferido',['WhatsApp','Correo','Ambos']) +
    select(c,'activo','Activo',['Sí','No']) +
    select(c,'nivel','Nivel en proceso',[1,2,3,4,5,6]) +
    select(c,'estado','Estado del nivel',ESTADOS) +
    select(c,'ultimoDesbloqueado','Último nivel desbloqueado',[0,1,2,3,4,5,6]) +
    select(c,'claridad','¿Claridad mínima? (N1–N3)',['Sí','No']) +
    campo(c,'ultimoContacto','Último contacto','date') +
    campo(c,'linkDashboard','Link del dashboard','text') +
  '</div>' +
  '<div class="grid2">' +
    area(c,'motor','Mensaje del Motor de Interpretación') +
    area(c,'preguntas','Preguntas de afinación') +
  '</div>' +
  '<div class="grid2">' +
    campo(c,'linkRadar','Link del Radar (cuando exista)','text') +
    area(c,'notas','Notas internas') +
  '</div>';

  if(an.alerta) h += '<div class="aviso-caja' + (an.alerta.startsWith('🚫') ? ' roja' : '') + '">' + esc(an.alerta) + '</div>';

  h += '<div class="coleccion-mini"><b style="color:var(--morado)">Colección Ordy:</b><br>' + esc(coleccionTexto(c)) + '</div>';

  if(an.tpl){
    const wa = mensajeWA(c, an.tpl);
    const mail = correoHTML(c, an.tpl);
    h += '<div class="bloque"><h3>📱 WhatsApp listo para enviar</h3>' +
      '<div class="msg-out">' + esc(wa) + '</div>' +
      '<div class="botonera">' +
        '<button class="btn verde" onclick="enviarWA(\'' + c.id + '\')" ' + (c.whatsapp ? '' : 'disabled') + '>Abrir WhatsApp</button>' +
        '<button class="btn linea" onclick="copiarWA(\'' + c.id + '\')">Copiar texto</button>' +
      '</div>' + (c.whatsapp ? '' : '<p class="nota-pie">Agregá el número de WhatsApp para activar el botón.</p>') +
    '</div>';

    h += '<div class="bloque"><h3>💌 Correo bonito</h3>' +
      '<p style="font-size:.85rem;color:var(--gris)"><b>Asunto:</b> ' + esc(mail.asunto) + '</p>' +
      '<div class="preview-mail">' + mail.html + '</div>' +
      '<div class="botonera">' +
        '<button class="btn morado" onclick="copiarCorreoHTML(\'' + c.id + '\')">Copiar correo con formato</button>' +
        '<button class="btn linea" onclick="copiarAsunto(\'' + c.id + '\')">Copiar asunto</button>' +
        '<button class="btn linea" onclick="abrirMailto(\'' + c.id + '\')" ' + (c.correo ? '' : 'disabled') + '>Correo rápido (texto)</button>' +
      '</div>' +
      '<p class="nota-pie">Flujo: abrí Gmail → mensaje nuevo → pegá el asunto → pegá el cuerpo con Ctrl+V (o Cmd+V) → revisá → enviar.</p>' +
    '</div>';

    h += '<div class="botonera" style="margin-top:14px">' +
      '<button class="btn coral" onclick="marcarEnviado(\'' + c.id + '\')">✓ Marcar como enviado</button>';
    if(c.estado === 'Desbloqueado' && parseInt(c.nivel) < 6){
      h += '<button class="btn morado" onclick="avanzarNivel(\'' + c.id + '\')">↗ Avanzar al Nivel ' + (parseInt(c.nivel)+1) + '</button>';
    }
    h += '</div>';
  } else {
    h += '<div class="bloque"><h3>🌊 Sin mensaje pendiente</h3><p style="font-size:.9rem;color:var(--gris)">' + esc(an.accion) + '. Cuando cambiés el estado, el panel armará el mensaje que toca.</p></div>';
  }

  h += '<div class="botonera" style="margin-top:14px"><button class="btn gris" onclick="eliminarCliente(\'' + c.id + '\')">🗑 Eliminar empresa</button></div>';
  return h;
}

function campo(c, k, label, tipo){
  return '<div class="campo"><label>' + label + '</label><input type="' + tipo + '" value="' + esc(c[k] || '') + '" onchange="editar(\'' + c.id + '\',\'' + k + '\',this.value)"></div>';
}
function area(c, k, label){
  return '<div class="campo"><label>' + label + '</label><textarea onchange="editar(\'' + c.id + '\',\'' + k + '\',this.value)">' + esc(c[k] || '') + '</textarea></div>';
}
function select(c, k, label, ops){
  return '<div class="campo"><label>' + label + '</label><select onchange="editar(\'' + c.id + '\',\'' + k + '\',this.value)">' +
    ops.map(o => '<option value="' + o + '"' + (String(c[k]) === String(o) ? ' selected' : '') + '>' + o + '</option>').join('') +
  '</select></div>';
}

function editar(id, k, v){
  const c = clientes.find(x => x.id === id);
  if(!c) return;
  c[k] = v;
  // Ayudita: al marcar Desbloqueado, actualizar el último nivel desbloqueado automáticamente
  if(k === 'estado' && v === 'Desbloqueado'){
    c.ultimoDesbloqueado = Math.max(parseInt(c.ultimoDesbloqueado)||0, parseInt(c.nivel)||1);
  }
  if(k === 'estado' && v === 'Radar listo'){ c.radarEnviado = false; }
  guardar(); pintarClientes();
}

function abrirNuevoCliente(){
  const c = { id:'c' + Date.now(), empresa:'Nueva empresa', nombre:'', whatsapp:'', correo:'',
    canal:'Ambos', activo:'Sí', nivel:1, estado:'Nuevo', ultimoDesbloqueado:0, claridad:'No',
    ultimoContacto:'', linkDashboard:'', motor:'', preguntas:'', linkRadar:'', notas:'' };
  clientes.unshift(c); abiertaId = c.id;
  guardar(); pintarClientes();
  document.getElementById('card-' + c.id)?.scrollIntoView({behavior:'smooth'});
}

function eliminarCliente(id){
  const c = clientes.find(x => x.id === id);
  if(!confirm('¿Eliminar a "' + c.empresa + '" del panel? El historial del registro se mantiene.')) return;
  clientes = clientes.filter(x => x.id !== id);
  abiertaId = null; guardar(); pintarClientes();
  toast('Empresa eliminada');
}

function avanzarNivel(id){
  const c = clientes.find(x => x.id === id);
  c.ultimoDesbloqueado = Math.max(parseInt(c.ultimoDesbloqueado)||0, parseInt(c.nivel)||1);
  c.nivel = Math.min(6, (parseInt(c.nivel)||1) + 1);
  c.estado = 'Pendiente';
  c.claridad = 'No';
  guardar(); pintarClientes();
  toast('Avanzó al Nivel ' + c.nivel + ' 🌊');
}

/* ═══════════ ENVÍOS ═══════════ */
function telCR(t){
  let d = (t||'').replace(/\D/g,'');
  if(d && !d.startsWith('506')) d = '506' + d;
  return d;
}
function enviarWA(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  if(!an.tpl) return;
  window.open('https://wa.me/' + telCR(c.whatsapp) + '?text=' + encodeURIComponent(mensajeWA(c, an.tpl)), '_blank');
}
async function copiarWA(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  await navigator.clipboard.writeText(mensajeWA(c, an.tpl));
  toast('Mensaje de WhatsApp copiado ✅');
}
async function copiarAsunto(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  await navigator.clipboard.writeText(correoHTML(c, an.tpl).asunto);
  toast('Asunto copiado ✅');
}
async function copiarCorreoHTML(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  const mail = correoHTML(c, an.tpl);
  const textoPlano = sustituir(TPL[an.tpl].correo, c, 'texto');
  try{
    await navigator.clipboard.write([ new ClipboardItem({
      'text/html': new Blob([mail.html], {type:'text/html'}),
      'text/plain': new Blob([textoPlano], {type:'text/plain'})
    })]);
    toast('Correo con formato copiado 💌 Pegalo en Gmail');
  }catch(e){
    // Respaldo para navegadores viejos
    const div = document.createElement('div');
    div.contentEditable = true; div.innerHTML = mail.html;
    div.style.position = 'fixed'; div.style.left = '-9999px';
    document.body.appendChild(div);
    const r = document.createRange(); r.selectNodeContents(div);
    const s = getSelection(); s.removeAllRanges(); s.addRange(r);
    document.execCommand('copy');
    div.remove();
    toast('Correo copiado 💌 Pegalo en Gmail');
  }
}
function abrirMailto(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  const asunto = correoHTML(c, an.tpl).asunto;
  const cuerpo = sustituir(TPL[an.tpl].correo, c, 'texto');
  location.href = 'mailto:' + c.correo + '?subject=' + encodeURIComponent(asunto) + '&body=' + encodeURIComponent(cuerpo);
}

function marcarEnviado(id){
  const c = clientes.find(x => x.id === id);
  const an = analizar(c);
  registro.unshift({ fecha:hoy(), empresa:c.empresa, nivel:c.nivel, estado:c.estado, plantilla:an.tpl || '—', canal:c.canal || '—' });
  c.ultimoContacto = hoy();
  if(an.tpl === 'RADAR') c.radarEnviado = true;
  guardar(); pintarClientes();
  toast('Registrado ✅ Último contacto: hoy');
}

/* ═══════════ REGISTRO ═══════════ */
function pintarRegistro(){
  const cont = document.getElementById('tabla-registro');
  if(registro.length === 0){
    cont.innerHTML = '<div class="vacio"><span class="emoji">📋</span>Todavía no hay envíos registrados.<br>Cada vez que marqués un mensaje como enviado, quedará guardado aquí.</div>';
    return;
  }
  cont.innerHTML = '<table><thead><tr><th>Fecha</th><th>Empresa</th><th>Nivel</th><th>Estado</th><th>Plantilla</th><th>Canal</th></tr></thead><tbody>' +
    registro.map(r => '<tr><td>' + r.fecha + '</td><td>' + esc(r.empresa) + '</td><td>N' + r.nivel + '</td><td>' + esc(r.estado) + '</td><td>' + esc(r.plantilla) + '</td><td>' + esc(r.canal) + '</td></tr>').join('') +
  '</tbody></table>';
}

/* ═══════════ CONFIGURACIÓN Y RESPALDO ═══════════ */
function abrirConfig(){
  document.getElementById('cfg-wa').value = config.wa || '';
  document.getElementById('cfg-comunidad').value = config.comunidad || '';
  document.getElementById('modal-config').classList.add('visible');
}
function guardarConfig(){
  config.wa = telCR(document.getElementById('cfg-wa').value);
  config.comunidad = document.getElementById('cfg-comunidad').value.trim();
  guardar(); cerrarModal('modal-config'); pintarClientes();
  toast('Configuración guardada ✅');
}
function cerrarModal(id){ document.getElementById(id).classList.remove('visible'); }

function descargarRespaldo(){
  const datos = { version:1, fecha:hoy(), clientes, registro, config };
  const blob = new Blob([JSON.stringify(datos, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'respaldo-ordy-' + hoy() + '.json';
  a.click();
  toast('Respaldo descargado ⬇');
}
function cargarRespaldo(input){
  const file = input.files[0];
  if(!file) return;
  const r = new FileReader();
  r.onload = () => {
    try{
      const d = JSON.parse(r.result);
      if(!d.clientes) throw new Error();
      if(!confirm('Esto reemplaza los datos actuales del panel con el respaldo del ' + (d.fecha || '?') + '. ¿Continuar?')) return;
      clientes = d.clientes; registro = d.registro || []; config = d.config || config;
      guardar(); pintarClientes(); pintarRegistro();
      toast('Respaldo cargado ✅');
    }catch(e){ alert('Ese archivo no parece un respaldo válido de Ordy.'); }
  };
  r.readAsText(file);
  input.value = '';
}

pintarClientes();
</script>

